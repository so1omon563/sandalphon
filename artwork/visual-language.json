  "typography": {
    "family": "system-ui, -apple-system, BlinkMacSystemFont, Helvetica Neue, Arial, sans-serif",
    "key": {
      "size": 18,
      "weight": 700,
      "maxLines": 2,
      "maxCharactersPerLine": 12
    },
    "touch": {
      "titleSize": 16,
      "detailSize": 13,
      "weight": 600,
      "maxCharacters": 18
    }
  },
  "geometry": {
    "key": {
      "width": 144,
      "height": 144,
      "safeInset": 12,
      "cornerRadius": 18
    },
    "touchQuarter": {
      "width": 200,
      "height": 100,
      "safeInset": 12,
      "cornerRadius": 12
    },
    "strokeWidth": 7,
    "lineCap": "round",
    "lineJoin": "round"
  },
  "motion": {
    "animatedAssets": false,
    "looping": false,
    "attentionTreatment": "static-accent-and-glyph",
    "transientFeedback": "stream-deck-show-ok-or-alert"
  }
}
