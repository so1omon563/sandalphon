    },
    "working": {
      "accent": "#72E2F1",
      "glyph": "flow",
      "label": "Working"
    },
    "waiting": {
      "accent": "#FFD166",
      "glyph": "pause",
      "label": "Waiting"
    },
    "completed": {
      "accent": "#72E6A5",
      "glyph": "check",
      "label": "Complete"
    },
    "failed": {
      "accent": "#FF7B72",
      "glyph": "cross",
      "label": "Failed"
    },
    "unavailable": {
      "accent": "#A7B0C0",
      "glyph": "blocked",
      "label": "Offline"
    }
  },
  "actionIconOrder": [
    "session",
    "resume",
    "inspect",
    "details",
    "exit",
    "attention",
    "review",
