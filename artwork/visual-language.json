{
  "schemaVersion": 1,
  "name": "Liminal Signal",
  "license": "MIT",
  "provenance": "repository-authored",
  "colors": {
    "canvas": "#090D1C",
    "surface": "#172348",
    "text": "#F5FBFF",
    "mutedText": "#C4CEE0",
    "focus": "#9A87FF"
  },
  "stateOrder": [
    "idle",
