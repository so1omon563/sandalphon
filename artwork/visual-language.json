      "glyph": "reasoning",
      "label": "Reasoning",
      "accent": "#9A87FF"
    },
    "retry": { "glyph": "retry", "label": "Retry", "accent": "#9A87FF" },
    "cancel": { "glyph": "cancel", "label": "Cancel", "accent": "#FF7B72" },
    "back": { "glyph": "back", "label": "Back", "accent": "#9A87FF" },
    "home": { "glyph": "home", "label": "Home", "accent": "#9A87FF" },
