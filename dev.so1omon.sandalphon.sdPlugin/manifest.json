{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/foundation-status",
      "Name": "Enter Sandalphon",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": true,
          "Title": "Enter\nSandalphon",
          "TitleAlignment": "bottom"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Open Sandalphon's managed Stream Deck + profile.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.foundation-status"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/foundation-status",
      "Name": "Managed Plus Key",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": false,
          "Title": "Sandalphon",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "One managed key in Sandalphon's Stream Deck + profile.",
      "UserTitleEnabled": false,
      "VisibleInActionsList": false,
      "UUID": "dev.so1omon.sandalphon.managed-plus"
    },
    {
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "$A1"
      },
      "Icon": "imgs/actions/foundation-status",
      "Name": "Managed Plus Encoder",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": false,
          "Title": "Sandalphon",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "One managed dial in Sandalphon's Stream Deck + profile.",
      "UserTitleEnabled": false,
      "VisibleInActionsList": false,
      "UUID": "dev.so1omon.sandalphon.managed-plus-encoder"
    }
  ],
  "Author": "Jedidiah Foster",
  "Category": "Sandalphon",
  "CategoryIcon": "imgs/category",
  "CodePath": "bin/plugin.js",
  "Description": "A human interface layer for directing and supervising software agents.",
  "Icon": "imgs/plugin",
  "Name": "Sandalphon",
  "Nodejs": {
    "Version": "24"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    }
  ],
  "Profiles": [
    {
      "AutoInstall": true,
      "DeviceType": 7,
      "DontAutoSwitchWhenInstalled": true,
      "Name": "profiles/Sandalphon Plus",
      "Readonly": true
    }
  ],
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "SupportURL": "https://github.com/so1omon563/sandalphon/issues",
  "URL": "https://github.com/so1omon563/sandalphon",
  "UUID": "dev.so1omon.sandalphon",
  "Version": "0.0.1.0"
}