{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/composable-status",
      "Name": "Session Status",
      "States": [
        {
          "Image": "imgs/actions/composable-status",
          "ShowTitle": false,
          "Title": "Session Status",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Show the selected Sandalphon session and its current state.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.composable-status"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/composable-resume",
      "Name": "Resume Session",
      "States": [
        {
          "Image": "imgs/actions/composable-resume",
          "ShowTitle": false,
          "Title": "Resume",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Resume the selected historical session when Sandalphon offers a current safe Resume action.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.composable-resume"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/composable-review",
      "Name": "Review Changes",
      "States": [
        {
          "Image": "imgs/actions/composable-review",
          "ShowTitle": false,
          "Title": "Review",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Start an official Codex review for the selected idle Sandalphon-owned session.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.composable-review"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/composable-attention",
      "Name": "Attention",
      "States": [
        {
          "Image": "imgs/actions/composable-attention",
          "ShowTitle": false,
          "Title": "Attention",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Show attention and select the next session that needs review without deciding the request.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.composable-attention"
    },
    {
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/plus-quarter.json"
      },
      "Icon": "imgs/actions/composable-session-dial",
      "Name": "Sessions",
      "States": [
        {
          "Image": "imgs/actions/composable-session-dial",
          "ShowTitle": false,
          "Title": "Sessions",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Preview sessions with the dial and press to select the previewed session.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.composable-session-dial"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/foundation-status",
      "Name": "Open Managed Surface",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": true,
          "Title": "Managed\nSurface",
          "TitleAlignment": "bottom"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "Open Sandalphon's optional full-device reference and validation surface.",
      "UserTitleEnabled": false,
      "UUID": "dev.so1omon.sandalphon.foundation-status"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/foundation-status",
      "Name": "Managed Classic 15 Key",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": false,
          "Title": "Sandalphon",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "One managed key in Sandalphon's Stream Deck Classic 15 profile.",
      "UserTitleEnabled": false,
      "VisibleInActionsList": false,
      "UUID": "dev.so1omon.sandalphon.managed-classic15"
    },
    {
      "Controllers": [
        "Keypad"
      ],
      "Icon": "imgs/actions/foundation-status",
      "Name": "Managed Plus Key",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": false,
          "Title": "Sandalphon",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "One managed key in Sandalphon's Stream Deck + profile.",
      "UserTitleEnabled": false,
      "VisibleInActionsList": false,
      "UUID": "dev.so1omon.sandalphon.managed-plus"
    },
    {
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "$A1"
      },
      "Icon": "imgs/actions/foundation-status",
      "Name": "Managed Plus Encoder",
      "States": [
        {
          "Image": "imgs/actions/foundation-status-key",
          "ShowTitle": false,
          "Title": "Sandalphon",
          "TitleAlignment": "middle"
        }
      ],
      "SupportedInKeyLogicActions": false,
      "SupportedInMultiActions": false,
      "Tooltip": "One managed dial in Sandalphon's Stream Deck + profile.",
      "UserTitleEnabled": false,
      "VisibleInActionsList": false,
      "UUID": "dev.so1omon.sandalphon.managed-plus-encoder"
    }
  ],
  "Author": "Jedidiah Foster",
  "Category": "Sandalphon",
  "CategoryIcon": "imgs/category",
  "CodePath": "bin/plugin.js",
  "Description": "A human interface layer for directing and supervising software agents.",
  "Icon": "imgs/plugin",
  "Name": "Sandalphon",
  "Nodejs": {
    "Version": "24"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    }
  ],
  "Profiles": [
    {
      "AutoInstall": true,
      "DeviceType": 0,
      "DontAutoSwitchWhenInstalled": true,
      "Name": "profiles/Sandalphon Classic 15",
      "Readonly": true
    },
    {
      "AutoInstall": true,
      "DeviceType": 7,
      "DontAutoSwitchWhenInstalled": true,
      "Name": "profiles/Sandalphon Plus",
      "Readonly": true
    }
  ],
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "SupportURL": "https://github.com/so1omon563/sandalphon/issues",
  "URL": "https://github.com/so1omon563/sandalphon",
  "UUID": "dev.so1omon.sandalphon",
  "Version": "0.0.1.0"
}